-- Xử lý Auto Teleport EternalOrb
teleportButton.MouseButton1Click:Connect(function()
    teleportRunning = not teleportRunning
    if teleportRunning then
        teleportButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        teleportButton.Text = "Auto Teleport EternalOrb: ON"
        task.spawn(function()
            local orbIndex = 1
            while teleportRunning do
                local combatFolder = workspace:FindFirstChild("CombatFolder")
                if combatFolder then
                    local secretPlayer = combatFolder:FindFirstChild("secret_player1225")
                    if secretPlayer then
                        local eternalOrb = secretPlayer:FindFirstChild("EternalOrb")
                        if eternalOrb then
                            -- Lấy tất cả các con là BasePart
                            local parts = {}
                            for _, child in ipairs(eternalOrb:GetChildren()) do
                                if child:IsA("BasePart") then
                                    table.insert(parts, child)
                                end
                            end
                            if #parts == 0 and eternalOrb:IsA("BasePart") then
                                parts = { eternalOrb }
                            end

                            if #parts > 0 then
                                local orb = parts[orbIndex]
                                if orb then
                                    local character = player.Character
                                    if character and character:FindFirstChild("HumanoidRootPart") then
                                        character.HumanoidRootPart.CFrame = orb.CFrame
                                    end
                                end
                                orbIndex = orbIndex + 1
                                if orbIndex > #parts then
                                    orbIndex = 1
                                end
                            end
                        end
                    end
                end
                task.wait(0.0001)  -- spam teleport
            end
        end)
    else
        teleportButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        teleportButton.Text = "Auto Teleport EternalOrb: OFF"
    end
end)

-- XỬ LÝ AUTO TELEPORT CHAOS
chaosButton.MouseButton1Click:Connect(function()
    chaosRunning = not chaosRunning
    if chaosRunning then
        chaosButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        chaosButton.Text = "Auto Teleport Chaos: ON"
        task.spawn(function()
            local enemyIndex = 1
            while chaosRunning do
                local enemies = workspace:FindFirstChild("Enemies")
                if enemies then
                    local chaos = enemies:FindFirstChild("Chaos")
                    if chaos then
                        -- Lấy danh sách các Enemy con
                        local enemyList = chaos:GetChildren()
                        local locations = {}
                        for _, enemy in ipairs(enemyList) do
                            local loc = enemy:FindFirstChild("EnemyLocation")
                            if loc and loc:IsA("BasePart") then
                                table.insert(locations, loc)
                            end
                        end
                        if #locations > 0 then
                            local target = locations[enemyIndex]
                            if target then
                                local character = player.Character
                                if character and character:FindFirstChild("HumanoidRootPart") then
                                    character.HumanoidRootPart.CFrame = target.CFrame
                                end
                            end
                            enemyIndex = enemyIndex + 1
                            if enemyIndex > #locations then
                                enemyIndex = 1
                            end
                        end
                    end
                end
                task.wait(60)  -- spam teleport
            end
        end)
    else
        chaosButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        chaosButton.Text = "Auto Teleport Chaos: OFF"
    end
end)

-- XỬ LÝ AUTO TELEPORT CURSE ORB (tất cả các CurseOrb)
curseButton.MouseButton1Click:Connect(function()
    curseRunning = not curseRunning
    if curseRunning then
        curseButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        curseButton.Text = "Auto Teleport Curse Orb: ON"
        task.spawn(function()
            local orbIndex = 1
            while curseRunning do
                local combatFolder = workspace:FindFirstChild("CombatFolder")
                if combatFolder then
                    local secretPlayer = combatFolder:FindFirstChild("secret_player1225")
                    if secretPlayer then
                        -- Lấy tất cả các part có tên chứa "CurseOrb"
                        local curseOrbs = {}
                        for _, child in ipairs(secretPlayer:GetChildren()) do
                            if child:IsA("BasePart") and child.Name:find("CurseOrb") then
                                table.insert(curseOrbs, child)
                            end
                        end
                        -- Nếu không tìm thấy, thử dùng CurseOrb_4 cụ thể
                        if #curseOrbs == 0 then
                            local orb4 = secretPlayer:FindFirstChild("CurseOrb_4")
                            if orb4 and orb4:IsA("BasePart") then
                                curseOrbs = { orb4 }
                            end
                        end

                        if #curseOrbs > 0 then
                            local target = curseOrbs[orbIndex]
                            if target then
                                local character = player.Character
                                if character and character:FindFirstChild("HumanoidRootPart") then
                                    character.HumanoidRootPart.CFrame = target.CFrame
                                end
                            end
                            orbIndex = orbIndex + 1
                            if orbIndex > #curseOrbs then
                                orbIndex = 1
                            end
                        end
                    end
                end
                task.wait(0.0001)  -- spam teleport
            end
        end)
    else
        curseButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        curseButton.Text = "Auto Teleport Curse Orb: OFF"
    end
end)

