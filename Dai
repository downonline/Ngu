// Đảm bảo có ít nhất 300 loại (hiện tại khoảng 200, cần thêm 100)
// Tôi sẽ thêm nhanh 100 loại bằng vòng lặp khi khởi tạo (để code gọn)
function expandCoTrungDB() {
    const prefixes = ["Huyền", "Thiên", "Địa", "Nhân", "Thần", "Ma", "Phật", "Tiên", "Quỷ", "Thánh"];
    const names = ["Huyết", "Kiếm", "Đao", "Thương", "Kích", "Phủ", "Chùy", "Biến", "Hóa", "Không"];
    const types = ["Lực đạo", "Huyết đạo", "Kiếm đạo", "Phòng ngự", "Trí đạo", "Hỏa đạo", "Thủy đạo", "Phong đạo"];
    for (let i = 1; i <= 100; i++) {
        let prefix = prefixes[i % prefixes.length];
        let name = names[i % names.length];
        let type = types[i % types.length];
        let rank = Math.floor(Math.random() * 5) + 1; // hạng 1-5
        let price = rank * 100 + i;
        let atk = rank * 10 + (i % 20);
        let def = rank * 8 + (i % 15);
        let spd = rank * 5 + (i % 10);
        let expYield = rank * 20 + i;
        let coName = `${prefix} ${name} Cổ ${i}`;
        CO_TRUNG_DB[coName] = {rank, type, price, baseAtk: atk, baseDef: def, speed: spd, expYield};
    }
}
