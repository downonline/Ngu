        if(input.length < 2) return message.reply("Cú pháp: `!hopluyen cổ1 | cổ2`");
        const p = data[uid];
        const idx1 = p.co_trung.findIndex(c => c.ten.toLowerCase() === input[0]);
        if(idx1 === -1) return message.reply(`Không có ${input[0]}`);
        const idx2 = p.co_trung.findIndex(c => c.ten.toLowerCase() === input[1]);
        if(idx2 === -1) return message.reply(`Không có ${input[1]}`);
        const co1 = p.co_trung[idx1];
        const co2 = p.co_trung[idx2];
        const rank1 = CO_TRUNG_DB[co1.ten].rank;
        const rank2 = CO_TRUNG_DB[co2.ten].rank;
        if(rank1 !== rank2) return message.reply("Hai cổ phải cùng hạng mới hợp luyện!");
        p.co_trung.splice(idx1,1);
        p.co_trung.splice(idx2 > idx1 ? idx2-1 : idx2,1);
