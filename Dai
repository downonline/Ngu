        data[target.id].co_trung.push(co);
        saveData(data);
        return message.reply(`🎁 Đã chuyển **${co.ten}** cho ${target.username}.`);
    }

    // ---- HỢP LUYỆN NÂNG CAO (có thể chọn hướng) ----
