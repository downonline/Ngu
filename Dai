    // ---- BÁN CỔ TRÙNG ----
    if (command === 'ban_co') {
        let ten = args.join(' ').toLowerCase();
        let idx = data[uid].co_trung.findIndex(c => c.ten.toLowerCase() === ten);
        if(idx === -1) return message.reply("Bạn không có cổ trùng này để bán!");
