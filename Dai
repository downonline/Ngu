        saveData(data);
        let embed = new EmbedBuilder()
            .setTitle(`⚔️ ĐẤU TRƯỜNG: ${message.author.username} vs ${doiThu.username}`)
            .setColor(winner === uid ? 0x00ff00 : 0xff0000)
