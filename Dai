            );
        return message.reply({ embeds: [embed] });
    }

    // ---- BẢNG XẾP HẠNG SỨC MẠNH ----
    if (command === 'xep_hang') {
        let rankings = [];
        for(let [id, userData] of Object.entries(data)) {
            let topCo = userData.co_trung[0];
            let power = topCo ? tinhSucManh(topCo, topCo.capDo) : 0;
            rankings.push({ id, power, name: client.users.cache.get(id)?.username || id });
        }
        rankings.sort((a,b) => b.power - a.power);
        let top10 = rankings.slice(0,10);
        let desc = top10.map((r, i) => `${i+1}. ${r.name} - SM: ${r.power}`).join('\n');
        const embed = new EmbedBuilder().setTitle('🏆 Bảng xếp hạng Thiên Hạ').setDescription(desc || "Chưa có dữ liệu").setColor(0xffd700);
        return message.reply({ embeds: [embed] });
    }

    // ---- NHIỆM VỤ HÀNG NGÀY ----
    if (command === 'nhiemvu_hangngay') {
        let nv = data[uid].nhiemVuHangNgay;
        let now = Date.now();
        if(now - nv.lastReset > 86400000) {
            nv.lastReset = now;
            nv.daLam = false;
            let loai = randomChoice(["đánh bại 3 người", "thu thập 1000 đá", "hợp luyện 1 lần", "tập luyện 5 lần"]);
            nv.loai = loai;
            nv.tienDo = 0;
            saveData(data);
        }
        if(nv.daLam) return message.reply("Hôm nay bạn đã hoàn thành nhiệm vụ rồi!");
        // Giả lập hoàn thành ngay (có thể check tiến độ thực tế nhưng để đơn giản thì dùng button)
        let row = new ActionRowBuilder().addComponents(
            new ButtonBuilder().setCustomId('hoanthanh_nv').setLabel('Hoàn thành').setStyle(ButtonStyle.Success)
        );
        await message.reply({ content: `📜 Nhiệm vụ hôm nay: ${nv.loai}. Bấm nút để nhận thưởng.`, components: [row] });
        const filter = i => i.customId === 'hoanthanh_nv' && i.user.id === uid;
        const collector = message.channel.createMessageComponentCollector({ filter, time: 60000 });
        collector.on('collect', async i => {
            let reward = randomInt(500, 1500);
            data[uid].da_nguyen += reward;
            data[uid].nhiemVuHangNgay.daLam = true;
            saveData(data);
            await i.update({ content: `✅ Hoàn thành nhiệm vụ! Nhận ${reward} đá nguyên.`, components: [] });
        });
    }

    // ---- SỰ KIỆN NGẪU NHIÊN ----
    if (command === 'sukien') {
        let result = randomEvent(uid, data);
        return message.reply(result);
    }

    // ---- KHO BẢO QUẢN (chuyển cổ trùng vào kho) ----
    if (command === 'kho') {
        if(args[0] === 'cat') {
            let ten = args.slice(1).join(' ').toLowerCase();
            let idx = data[uid].co_trung.findIndex(c => c.ten.toLowerCase() === ten);
            if(idx === -1) return message.reply("Không tìm thấy!");
            let co = data[uid].co_trung[idx];
            data[uid].co_trung.splice(idx,1);
            data[uid].kho.push(co);
            saveData(data);
            return message.reply(`Đã cất ${co.ten} vào kho.`);
        } else if(args[0] === 'lay') {
            let ten = args.slice(1).join(' ').toLowerCase();
            let idx = data[uid].kho.findIndex(c => c.ten.toLowerCase() === ten);
            if(idx === -1) return message.reply("Không có trong kho!");
            let co = data[uid].kho[idx];
            data[uid].kho.splice(idx,1);
            data[uid].co_trung.push(co);
            saveData(data);
            return message.reply(`Đã lấy ${co.ten} ra khỏi kho.`);
        } else {
            let listKho = data[uid].kho.map(c => c.ten).join(', ');
            return message.reply(`📦 Kho của bạn: ${listKho || "Trống"}`);
        }
    }

    // ---- BANG PHÁI (tạo, tham gia) ----
    if (command === 'bang_phai') {
        let sub = args[0];
        if(sub === 'tao') {
            let tenBang = args.slice(1).join(' ');
            if(!tenBang) return message.reply("Cú pháp: `!bang_phai tao [tên bang]`");
            if(data[uid].bangPhai) return message.reply("Bạn đã ở trong bang rồi!");
            if(Object.values(guilds).some(g => g.name === tenBang)) return message.reply("Tên bang đã tồn tại!");
            let bangId = Date.now().toString();
            guilds[bangId] = { name: tenBang, members: [uid], level: 1, exp: 0, leader: uid };
            data[uid].bangPhai = bangId;
            saveData(data);
            return message.reply(`🏮 Đã tạo bang **${tenBang}** thành công!`);
        } else if(sub === 'gia_nhap') {
            let tenBang = args.slice(1).join(' ');
            let bang = Object.values(guilds).find(g => g.name === tenBang);
            if(!bang) return message.reply("Bang không tồn tại!");
            if(data[uid].bangPhai) return message.reply("Bạn đã có bang!");
            bang.members.push(uid);
            data[uid].bangPhai = Object.keys(guilds).find(key => guilds[key] === bang);
            saveData(data);
            return message.reply(`Bạn đã gia nhập bang **${tenBang}**!`);
        } else if(sub === 'thong_tin') {
            if(!data[uid].bangPhai) return message.reply("Bạn chưa gia nhập bang nào!");
            let bang = guilds[data[uid].bangPhai];
            let memberList = bang.members.map(id => `<@${id}>`).join(', ');
            return message.reply(`🏛️ Bang **${bang.name}** (Cấp ${bang.level})\nThành viên: ${memberList}\nBang chủ: <@${bang.leader}>`);
        }
    }

    // ---- NHẬT KÝ GIAO DỊCH ----
    if (command === 'nhay_ky') {
        let logs = data[uid].nhayKy.slice(-10).map(log => log).join('\n');
        return message.reply(`📜 10 giao dịch gần nhất:\n${logs || "Chưa có"}`);
    }

    // ---- ĐỘT PHÁ ----
    if (command === 'dotpha') {
        const p = data[uid];
        const cost = p.rank * 300;
        if(p.chan_nguyen < cost) return message.reply(`Cần ${cost} Chân nguyên để phá vách khiếu!`);
        p.chan_nguyen -= cost;
        const rates = {"D": 0.4, "C": 0.55, "B": 0.7, "A": 0.85, "Thập Đại Cổ Thể": 1.0};
        if(Math.random() < rates[p.tuchat]) {
            p.rank += 1;
            p.thongKe.soLanDotPha++;
            message.reply(`⚡ Đột phá thành công lên **Hạng ${p.rank}**!`);
        } else {
            p.chan_nguyen = Math.floor(p.chan_nguyen * 0.5);
            message.reply("⚠️ Thất bại! Khí huyết bốc lên, mất nửa chân nguyên.");
        }
        saveData(data);
    }

    // ---- BẾ QUAN ----
    if (command === 'be_quan') {
        data[uid].chan_nguyen += 100 * data[uid].rank;
        saveData(data);
        return message.reply("🧘 Nhắm mắt minh tưởng. Chân nguyên đang trào dâng.");
    }

    // ---- OWNER COMMANDS ----
    if (uid === OWNER_ID) {
        if (command === 'ban_da') {
            const user = message.mentions.users.first();
            const amt = parseInt(args[1]);
            if(!user || isNaN(amt)) return message.reply("Cú pháp: `!ban_da @user số_lượng`");
            if(!data[user.id]) data[user.id] = initUser(user.id);
            data[user.id].da_nguyen += amt;
            saveData(data);
            return message.reply(`👑 Thiên Ý ban cho ${user.username} ${amt} Đá nguyên.`);
        }
        if (command === 'ban_co') {
            const user = message.mentions.users.first();
            const nameInput = args.slice(1).join(' ').toLowerCase();
            if(!user || !nameInput) return message.reply("Cú pháp: `!ban_co @user tên_cổ`");
            const realName = Object.keys(CO_TRUNG_DB).find(k => k.toLowerCase() === nameInput);
            if(!realName) return message.reply("Không có loại Cổ này!");
            if(!data[user.id]) data[user.id] = initUser(user.id);
            data[user.id].co_trung.push({ ten: realName, capDo: 1, exp: 0, daTienHoa: false });
            saveData(data);
            return message.reply(`👑 Đã ban **${realName}** cho ${user.username}.`);
        }
        if (command === 'reset_user') {
            const user = message.mentions.users.first();
            if(!user) return message.reply("Tag user cần reset!");
            delete data[user.id];
            saveData(data);
            return message.reply(`Đã reset toàn bộ dữ liệu của ${user.username}.`);
        }
    }
});

