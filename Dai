// ================== SHOP TỰ ĐỘNG ==================
function refreshShop() {
    const allKeys = Object.keys(CO_TRUNG_DB);
    const phamCoKeys = allKeys.filter(k => CO_TRUNG_DB[k].rank <= 5);
    const selectedPham = randomSample(phamCoKeys, 15);
    currentShop = {};
    selectedPham.forEach(k => { currentShop[k] = CO_TRUNG_DB[k]; });
    if (Math.random() < 0.05) {
        const tienCoKeys = allKeys.filter(k => CO_TRUNG_DB[k].rank >= 6);
        if(tienCoKeys.length) currentShop[randomChoice(tienCoKeys)] = CO_TRUNG_DB[randomChoice(tienCoKeys)];
    }
}

// ================== SỰ KIỆN NGẪU NHIÊN ==================
function randomEvent(userId, data) {
    const events = [
        { text: "Bắt gặp một con cổ trùng hoang dã! Bạn có thể bắt nó bằng cách dùng `!bat_co`", action: "wild" },
        { text: "Một lão tiền bối tặng bạn 500 đá nguyên.", reward: { da_nguyen: 500 } },
        { text: "Thiên tai ập đến, bạn mất 200 đá nguyên.", penalty: { da_nguyen: -200 } },
        { text: "Bạn tìm thấy bí tịch cổ trùng, kinh nghiệm tu luyện tăng gấp đôi trong 1 giờ.", effect: "double_exp" },
    ];
    const ev = randomChoice(events);
    if(ev.reward) {
        data[userId].da_nguyen += ev.reward.da_nguyen;
        saveData(data);
        return `🌠 SỰ KIỆN: ${ev.text}`;
    } else if(ev.penalty) {
        data[userId].da_nguyen = Math.max(0, data[userId].da_nguyen + ev.penalty.da_nguyen);
        saveData(data);
        return `🌠 SỰ KIỆN: ${ev.text}`;
    } else {
        return `🌠 SỰ KIỆN: ${ev.text}`;
    }
}

// ================== TÍNH SỨC MẠNH CỔ TRÙNG ==================
function tinhSucManh(coTrungObj, capDo) {
    let goc = CO_TRUNG_DB[coTrungObj.ten];
    if(!goc) return 0;
    let atk = goc.baseAtk + (capDo-1) * 2;
    let def = goc.baseDef + (capDo-1) * 2;
    let spd = goc.speed + (capDo-1) * 1;
    return atk + def + spd;
}

