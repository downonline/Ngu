        const price = currentShop[realName].price;
        if(data[uid].da_nguyen < price) return message.reply("Thiếu Đá nguyên!");
        data[uid].da_nguyen -= price;
        data[uid].co_trung.push({ ten: realName, capDo: 1, exp: 0, daTienHoa: false });
        saveData(data);
        return message.reply(`✅ Đã mua **${realName}**.`);
