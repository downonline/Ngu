// ================== TIỆN ÍCH ==================
function randomInt(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }
function randomChoice(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
function randomSample(arr, num) {
    const shuffled = [...arr].sort(() => 0.5 - Math.random());
    return shuffled.slice(0, num);
}
function weightedRandom(choices, weights) {
    let total = weights.reduce((a,b)=>a+b,0);
    let rand = Math.random() * total;
    let acc = 0;
    for(let i=0;i<choices.length;i++) {
        acc += weights[i];
        if(rand < acc) return choices[i];
    }
    return choices[choices.length-1];
}

// ================== QUẢN LÝ DỮ LIỆU NGƯỜI DÙNG MỚI ==================
function loadData() {
    try { return JSON.parse(fs.readFileSync('thien_ha.json', 'utf8')); }
    catch { return {}; }
}
function saveData(data) {
    fs.writeFileSync('thien_ha.json', JSON.stringify(data, null, 4), 'utf8');
}

